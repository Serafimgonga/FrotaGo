<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrotaGo.Mobile.Views.LessonListPage"
             Title="Aulas Agendadas">
  <CollectionView x:Name="LessonsView">
    <CollectionView.ItemTemplate>
      <DataTemplate>
        <Frame Margin="8" Padding="12">
          <VerticalStackLayout>
            <Label Text="{Binding StudentName}" FontAttributes="Bold"/>
            <Label Text="{Binding Vehicle}" />
            <Label Text="{Binding StartTime}" />
            <Button Text="Ver detalhes" Clicked="OnDetailsClicked"/>
          </VerticalStackLayout>
        </Frame>
      </DataTemplate>
    </CollectionView.ItemTemplate>
  </CollectionView>
</ContentPage>
