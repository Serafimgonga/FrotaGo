<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrotaGo.Mobile.Views.LoginPage"
             Title="Login"
             BackgroundColor="{StaticResource Background}">
  <ScrollView>
    <VerticalStackLayout Padding="16" Spacing="24">
      <!-- Header -->
      <VerticalStackLayout Spacing="8" Margin="0,32,0,24" HorizontalOptions="Center">
        <Label Text="FrotaGo" 
               FontSize="32" 
               FontAttributes="Bold"
               TextColor="{StaticResource Primary}"
               HorizontalOptions="Center"/>
        <Label Text="Acesso de Instrutor" 
               Style="{StaticResource CaptionStyle}"
               HorizontalOptions="Center"/>
      </VerticalStackLayout>

      <!-- Inputs -->
      <VerticalStackLayout Spacing="16">
        <VerticalStackLayout Spacing="4">
          <Label Text="Email" Style="{StaticResource CaptionStyle}"/>
          <Entry x:Name="UsernameEntry" 
                 Placeholder="seu.email@frotago.com"
                 Style="{StaticResource InputStyle}"
                 Keyboard="Email"/>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="4">
          <Label Text="Password" Style="{StaticResource CaptionStyle}"/>
          <Entry x:Name="PasswordEntry" 
                 Placeholder="••••••••"
                 IsPassword="True"
                 Style="{StaticResource InputStyle}"/>
        </VerticalStackLayout>
      </VerticalStackLayout>

      <!-- Botão Login -->
      <Button Text="Entrar" 
              Clicked="OnLoginClicked"
              Style="{StaticResource PrimaryButtonStyle}"
              Margin="16,16"/>

      <!-- Loading Indicator -->
      <ActivityIndicator x:Name="LoadingIndicator" 
                         IsRunning="False" 
                         IsVisible="False"
                         Color="{StaticResource Primary}"
                         Margin="0,16"/>

      <!-- Error Message -->
      <Label x:Name="ErrorLabel" 
             TextColor="{StaticResource Error}"
             FontSize="12"
             IsVisible="False"
             HorizontalTextAlignment="Center"
             Margin="16,0"/>
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
