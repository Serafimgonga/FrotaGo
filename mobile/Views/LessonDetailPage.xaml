<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrotaGo.Mobile.Views.LessonDetailPage"
             Title="Detalhes da Aula">
  <ScrollView>
    <VerticalStackLayout Padding="20" Spacing="12">
      <Label x:Name="TitleLabel" FontSize="22" />
      <Label x:Name="StudentLabel" />
      <Label x:Name="VehicleLabel" />
      <Label x:Name="StatusLabel" />
      <HorizontalStackLayout Spacing="12">
        <Button Text="Iniciar Aula" Clicked="OnStartLessonClicked"/>
        <Button Text="Finalizar Aula" Clicked="OnStopLessonClicked" />
      </HorizontalStackLayout>
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
