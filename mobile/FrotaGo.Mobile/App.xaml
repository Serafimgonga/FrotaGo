<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             x:Class="FrotaGo.Mobile.App">
  <Application.Resources>
    <!-- Paleta de Cores -->
    <Color x:Key="Primary">#2196F3</Color>
    <Color x:Key="PrimaryDark">#1976D2</Color>
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Background">#FFFFFF</Color>
    <Color x:Key="Surface">#F5F5F5</Color>
    <Color x:Key="TextPrimary">#212121</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="Border">#E0E0E0</Color>
    <Color x:Key="Placeholder">#999999</Color>

    <!-- Estilos de Texto -->
    <Style TargetType="Label" x:Key="PageTitleStyle">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontAttributes" Value="Bold"/>
      <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
      <Setter Property="Margin" Value="16,16,16,8"/>
    </Style>

    <Style TargetType="Label" x:Key="SectionTitleStyle">
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontAttributes" Value="Bold"/>
      <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
      <Setter Property="Margin" Value="16,12,16,8"/>
    </Style>

    <Style TargetType="Label" x:Key="BodyTextStyle">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
      <Setter Property="LineHeight" Value="1.5"/>
    </Style>

    <Style TargetType="Label" x:Key="CaptionStyle">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
    </Style>

    <!-- Estilos de Botões -->
    <Style TargetType="Button" x:Key="PrimaryButtonStyle">
      <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
      <Setter Property="TextColor" Value="White"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontAttributes" Value="Bold"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Margin" Value="16,8"/>
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButtonStyle">
      <Setter Property="BackgroundColor" Value="{StaticResource Surface}"/>
      <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Margin" Value="16,8"/>
      <Setter Property="BorderColor" Value="{StaticResource Border}"/>
      <Setter Property="BorderWidth" Value="1"/>
    </Style>

    <Style TargetType="Button" x:Key="DangerButtonStyle">
      <Setter Property="BackgroundColor" Value="{StaticResource Error}"/>
      <Setter Property="TextColor" Value="White"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontAttributes" Value="Bold"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Margin" Value="16,8"/>
    </Style>

    <!-- Estilos de Inputs -->
    <Style TargetType="Entry" x:Key="InputStyle">
      <Setter Property="BackgroundColor" Value="{StaticResource Background}"/>
      <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
      <Setter Property="PlaceholderColor" Value="{StaticResource Placeholder}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="12"/>
      <Setter Property="Margin" Value="16,8"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- Estilo de Card -->
    <Style TargetType="Frame" x:Key="CardStyle">
      <Setter Property="BackgroundColor" Value="{StaticResource Background}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="HasShadow" Value="True"/>
      <Setter Property="Padding" Value="16"/>
      <Setter Property="Margin" Value="16,8"/>
      <Setter Property="BorderColor" Value="{StaticResource Border}"/>
    </Style>

  </Application.Resources>
</Application>
